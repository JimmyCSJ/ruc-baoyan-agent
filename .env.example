# 用户登录（默认开启）；设为 false 可关闭 API 鉴权（便于本地调试/自动化测试）
AUTH_REQUIRED=true
# 账户与个人信息 JSON 存储目录（默认 data/auth）
# AUTH_DATA_DIR=data/auth
# 登录会话有效天数
AUTH_SESSION_DAYS=14

DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# 兼容旧代码路径；如不设置，程序会优先读取 DEEPSEEK_*。
# MOARK_API_KEY=
# MOARK_BASE_URL=https://api.deepseek.com
# MOARK_MODEL=deepseek-chat
# 仅有 API Key 不会启用模型；必须为 true
ENABLE_REAL_LLM=true
LLM_FAILOVER_ENABLED=true
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.7
LLM_MAX_TOKENS=8192
LLM_TOP_K=50
LLM_FREQUENCY_PENALTY=1

# 长程规划（五段流水线）：单次 HTTP 读超时（秒）；网关/代理 upstream 也需不小于该值
LONG_PLAN_LLM_TIMEOUT_S=900
# 每段 max_tokens 上限（env）；实际生效为 min(该值, LONG_PLAN_PART_OUTPUT_CEILING)，不与全局 LLM_MAX_TOKENS 取 max 拉大
LONG_PLAN_PART_MAX_TOKENS=8192
LONG_PLAN_PART_OUTPUT_CEILING=8192
LONG_PLAN_KB_CONTEXT_MAX_CHARS=50000
LONG_PLAN_CITATION_DOC_LIMIT=60
# LONG_PLAN_PART_RESPONSE_JSON=true

# 知识库管理：GET /api/admin/kb/inspect 与 /web/admin-kb.html
ENABLE_KB_ADMIN=true

# 联网（对齐 web-access：Jina 正文通道，可选 API Key 提额）
# WEB_SEARCH_USE_JINA=true
# JINA_API_KEY=
# WEB_SEARCH_MAX_FETCH=3

# web-access 主路径（CDP Proxy）：
WEB_ACCESS_PRIMARY=true
WEB_ACCESS_PROXY_URL=http://localhost:3456
WEB_ACCESS_TIMEOUT_S=14
WEB_ACCESS_MAX_PAGES=3
WEB_ACCESS_FALLBACK_ENABLED=true

# 仅公众信息库检索时的默认召回条数（防止只看到前几条）
KB_PUBLIC_TOP_K_PUBLIC_ONLY=120

# LLM 上下文打包预算（大召回后控制喂给模型的体积）
LLM_CONTEXT_MAX_CHARS=28000
LLM_CONTEXT_DOC_MAX_CHARS=700
LLM_CONTEXT_MAX_OFFICIAL_DOCS=18
LLM_CONTEXT_MAX_EXPERIENCE_DOCS=36
LLM_CONTEXT_MAX_WEB_DOCS=8
LLM_CONTEXT_MAX_OTHER_DOCS=6

# 混合检索（稠密 ChromaDB + 稀疏 BM25 + RRF 融合）
ENABLE_HYBRID_SEARCH=false
HYBRID_DENSE_TOP_K_MULT=2
HYBRID_SPARSE_TOP_K_MULT=2
HYBRID_RRF_K=60
# 设为 true 时通过兼容 embedding API 做向量索引；DeepSeek 官方 chat 接口不提供此 embedding 模型时请保持 false。
HYBRID_EMBEDDING_API=false
HYBRID_EMBEDDING_API_MODEL=BAAI/bge-m3

# 交叉编码器重排序（bge-reranker-v2-m3）
ENABLE_RERANKER=false
RERANKER_TOP_K=8
RERANKER_USE_FP16=false

# Text-to-SQL 数据 Agent（基于 ruc_2026_manual_stats.txt）
ENABLE_DATA_AGENT=false
DATA_AGENT_LLM_TIMEOUT_S=30
